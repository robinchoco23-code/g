local function trySell()
    local preview = nil
    pcall(function()
        preview = Networking.NPCS.PreviewSellAll:Fire()
    end)

    if not preview then
        SellStatus:SetText("Status: Preview failed")
        return
    end

    local fruitCount = preview.FruitCount or 0
    if fruitCount == 0 then
        SellStatus:SetText("Status: Nothing to sell")
        return
    end

    local result = nil
    pcall(function()
        result = Networking.NPCS.SellAll:Fire()
    end)

    if result and result.Success then
        sellCount = sellCount + 1
        SellStatus:SetText(string.format("Status: Sold %d items", result.SoldCount or fruitCount))
        SellCount:SetText("Sells: " .. sellCount)
    else
        SellStatus:SetText("Status: Failed / cooldown")
    end
end

-- =============================================
--  BUY LOGIC (Seed Shop)
--  One seed per tick to avoid coroutine spam.
-- =============================================
local _seedBuyList  = {}
local _seedBuyIndex = 1

local function tryBuy()
    local selected = Options.ShopSeeds.Value
    if not selected or not next(selected) then
        BuyStatus:SetText("Status: No seeds selected")
        return
    end

    _seedBuyList = {}
    for seed, active in pairs(selected) do
        if active then table.insert(_seedBuyList, seed) end
    end
    if #_seedBuyList == 0 then return end

    if _seedBuyIndex > #_seedBuyList then _seedBuyIndex = 1 end
    local seed = _seedBuyList[_seedBuyIndex]
    _seedBuyIndex = _seedBuyIndex + 1

    local ok = pcall(function()
        Networking.SeedShop.PurchaseSeed:Fire(seed)
    end)

    if ok then
        buyCount = buyCount + 1
        BuyStatus:SetText("Status: Bought " .. seed)
        BuyCount:SetText("Bought: " .. buyCount)
    else
        BuyStatus:SetText("Status: Failed / cooldown")
    end
end

-- =============================================
--  BUY LOGIC (Gear Shop)
--  Buys ONE item per call so the yielding Packet coroutine
--  fully resolves before the next fire (avoids "cannot resume
--  non-suspended coroutine" spam). The outer loop handles pacing.
-- =============================================
local _gearBuyList  = {}  -- ordered list of currently-selected gear
local _gearBuyIndex = 1   -- cycles through the list one item per tick

local function tryBuyGear()
    local selected = Options.ShopGear.Value
    if not selected or not next(selected) then
        GearBuyStatus:SetText("Status: No gear selected")
        return
    end

    -- Rebuild list whenever selection may have changed
    _gearBuyList = {}
    for gear, active in pairs(selected) do
        if active then table.insert(_gearBuyList, gear) end
    end
    if #_gearBuyList == 0 then return end

    -- Clamp index and advance for next call
    if _gearBuyIndex > #_gearBuyList then _gearBuyIndex = 1 end
    local gear = _gearBuyList[_gearBuyIndex]
    _gearBuyIndex = _gearBuyIndex + 1

    local ok = pcall(function()
        Networking.GearShop.PurchaseGear:Fire(gear)
    end)

    if ok then
        gearBuyCount = gearBuyCount + 1
        GearBuyStatus:SetText("Status: Bought " .. gear)
        GearBuyCount:SetText("Bought: " .. gearBuyCount)
    else
        GearBuyStatus:SetText("Status: Failed / cooldown")
    end
end

-- =============================================
--  PLANT LOGIC
-- =============================================
local function tryPlant()
    local plot = getMyPlot()
    if not plot then
        PlantStatus:SetText("Status: No plot found")
        return
    end

    local wanted = Options.PlantSeeds.Value
    local tool, seedType = getSeedToolMatching(wanted)
    if not tool then
        PlantStatus:SetText("Status: No matching seed in bag")
        return
    end

    local areas = getPlantAreas(plot)
    if #areas == 0 then
        PlantStatus:SetText("Status: No PlantAreaColumn found")
        return
    end

    local area = areas[math.random(1, #areas)]
    local pos  = randomPointOnPart(area)

    local ok = pcall(function()
        Networking.Plant.PlantSeed:Fire(pos, seedType, tool)
    end)

    if ok then
        plantCount = plantCount + 1
        PlantStatus:SetText("Status: Planted " .. tostring(seedType))
        PlantCount:SetText("Planted: " .. plantCount)
    else
        PlantStatus:SetText("Status: Fire error")
    end
end

-- =============================================
--  PET BUY LOGIC (hardened)
-- =============================================
local function petTypeFromName(name)
    local t = name:match("^WildPet_([%w]+)_")
    return t
end

local function getRoot()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

local function collectPetPrompts()
    local ok, list, errMsg = pcall(function()
        local map = workspace:FindFirstChild("Map")
        local spawns = map and map:FindFirstChild("WildPetSpawns")
        if not spawns then return nil, "No WildPetSpawns" end

        local wanted = Options.PetTypes.Value
        local buyAll = Toggles.BuyAllPets.Value

        local out = {}
        for _, prompt in ipairs(spawns:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                local action = (prompt.ActionText or ""):lower()
                if action == "" or action:find("buy") then
                    local owner = prompt:FindFirstAncestorWhichIsA("Model")
                    local part = owner and (owner.PrimaryPart
                        or owner:FindFirstChild("HumanoidRootPart")
                        or owner:FindFirstChildWhichIsA("BasePart"))
                    if part then
                        local pType = petTypeFromName(owner.Name)
                        local allow = buyAll
                        if not buyAll and pType and wanted and wanted[pType] then
                            allow = true
                        end
                        if allow then
                            table.insert(out, { prompt = prompt, part = part, ptype = pType })
                        end
                    end
                end
            end
        end
        return out, nil
    end)

    if not ok then
        return nil, "Scan error"
    end
    if list == nil then
        return nil, errMsg or "Unknown error"
    end
    return list
end

-- Fire a pet-buy prompt with retries, just like guaranteedFire in collectDrops
local function buyOnePet(entry)
    local prompt = entry.prompt
    local part   = entry.part

    if not prompt or not prompt.Parent or not part or not part.Parent then
        return false
    end

    -- Re-fetch root right before teleporting (handles respawn mid-loop)
    local r = getRoot()
    if not r then return false end

    pcall(function()
        r.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    end)
    task.wait(0.12)

    if not prompt.Parent then return false end

    local oldHold = prompt.HoldDuration
    pcall(function() prompt.HoldDuration = 0 end)

    local fired = false
    for attempt = 1, 3 do
        if not prompt.Parent then break end
        local fireOk = pcall(function() fireproximityprompt(prompt) end)
        if fireOk then
            fired = true
            break
        end
        task.wait(0.05)
    end

    pcall(function()
        if prompt and prompt.Parent then prompt.HoldDuration = oldHold end
    end)

    return fired
end

local function tryBuyPets()
    local root = getRoot()
    if not root then
        PetStatus:SetText("Status: No character")
        return
    end

    -- Capture return position FIRST, before anything that can yield/error
    local returnCF = root.CFrame

    -- Guaranteed return helper, mirrors alwaysReturn() in collectDrops
    local function alwaysReturnPet()
        if not Toggles.PetReturn.Value then return end
        for _ = 1, 3 do
            local r = getRoot()
            if r then
                pcall(function() r.CFrame = returnCF end)
            end
            task.wait(0.05)
        end
    end

    local list, err = collectPetPrompts()
    if not list then
        PetStatus:SetText("Status: " .. tostring(err))
        return
    end

    if #list == 0 then
        PetStatus:SetText("Status: No pets around")
        return
    end

    table.sort(list, function(a, b)
        return (a.part.Position - returnCF.Position).Magnitude
             < (b.part.Position - returnCF.Position).Magnitude
    end)

    local entry = list[1]
    PetStatus:SetText("Status: Buying " .. (entry.ptype or "pet"))

    -- Wrap the whole attempt so a mid-buy error can't skip the return teleport
    local bought = false
    pcall(function()
        bought = buyOnePet(entry)
    end)

    if bought then
        petCount = petCount + 1
        PetCount:SetText("Pets: " .. petCount)
        PetStatus:SetText("Status: Bought " .. (entry.ptype or "pet"))
    else
        PetStatus:SetText("Status: Buy failed, will retry")
    end

    alwaysReturnPet()
end

-- =============================================
--  AUTO DROPS LOGIC
--  Bulletproof: captures returnCF first, wraps entire sweep in pcall,
--  retries each prompt up to 3x, and ALWAYS teleports back no matter
--  what error or break happens.
-- =============================================
local function collectDrops()
    local root = getRoot()
    if not root then
        DropsStatus:SetText("Status: No character")
        return
    end

    -- Capture return position FIRST before any yields or errors can happen
    local returnCF = root.CFrame

    -- Guaranteed return helper — called in every exit path
    local function alwaysReturn()
        local r = getRoot()
        if r then
            -- retry the teleport a few times in case the character is mid-animation
            for _ = 1, 3 do
                pcall(function() r.CFrame = returnCF end)
                task.wait(0.05)
            end
        end
    end

    -- Scan a container for all enabled ProximityPrompts
    local function scanContainer(container, out)
        if not container then return end
        for _, desc in ipairs(container:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local part = desc.Parent
                if not (part and part:IsA("BasePart")) then
                    part = desc:FindFirstAncestorWhichIsA("BasePart")
                end
                if part then
                    table.insert(out, { prompt = desc, part = part })
                end
            end
        end
    end

    -- Fire one prompt with retries — zeros hold duration, fires up to 3 attempts
    local function guaranteedFire(prompt)
        if not prompt or not prompt.Parent then return false end

        local oldHold = 0
        pcall(function()
            oldHold = prompt.HoldDuration
            prompt.HoldDuration = 0
        end)

        local fired = false
        for attempt = 1, 3 do
            if not prompt.Parent then break end
            local ok = pcall(function() fireproximityprompt(prompt) end)
            if ok then
                fired = true
                break
            end
            task.wait(0.05)
        end

        pcall(function()
            if prompt and prompt.Parent then
                prompt.HoldDuration = oldHold
            end
        end)

        return fired
    end

    -- Wrap entire sweep so errors never skip the return
    local collected = 0
    pcall(function()
        local prompts = {}
        scanContainer(workspace:FindFirstChild("DroppedItems"), prompts)
        local map = workspace:FindFirstChild("Map")
        if map then
            scanContainer(map:FindFirstChild("SeedPackSpawnClient"), prompts)
            scanContainer(map:FindFirstChild("SeedPackSpawnServerLocations"), prompts)
        end

        if #prompts == 0 then
            DropsStatus:SetText("Status: Nothing to collect")
            return
        end

        -- Nearest-first to minimise travel
        table.sort(prompts, function(a, b)
            return (a.part.Position - returnCF.Position).Magnitude
                 < (b.part.Position - returnCF.Position).Magnitude
        end)

for _, entry in ipairs(prompts) do
    if not Alive() or not Toggles.AutoDrops.Value then break end

    local prompt = entry.prompt
    local part   = entry.part

    if not prompt or not prompt.Parent or not part or not part.Parent then
        continue
    end

    -- Re-fetch root each loop in case character respawned mid-sweep
    local r = getRoot()
    if not r then break end

    r.CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0))
    task.wait(0.15)

    local fired = guaranteedFire(prompt)

            if fired then
                collected = collected + 1
                dropCount = dropCount + 1
                DropsCount:SetText("Collected: " .. dropCount)
                DropsStatus:SetText("Status: Collecting... (" .. collected .. ")")
            end

            task.wait(Options.DropsDelay.Value)
        end

        if collected > 0 then
            DropsStatus:SetText("Status: Got " .. collected .. " drop(s)")
        else
            DropsStatus:SetText("Status: Nothing collected")
        end
    end)

    -- ALWAYS return — runs even if pcall caught an error or toggle was flipped
    alwaysReturn()
end
