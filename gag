-- =============================================
--  PLANT LOGIC
-- =============================================
local function tryPlant()
    local plot = getMyPlot()
    if not plot then
        PlantStatus:SetText("Status: No plot found")
        return
    end

    local wanted = Options.PlantSeeds.Value
    local tool, seedType = getSeedToolMatching(wanted)
    if not tool then
        PlantStatus:SetText("Status: No matching seed in bag")
        return
    end

    local areas = getPlantAreas(plot)
    if #areas == 0 then
        PlantStatus:SetText("Status: No PlantAreaColumn found")
        return
    end

    local area = areas[math.random(1, #areas)]
    local pos  = randomPointOnPart(area)

    local ok = pcall(function()
        Networking.Plant.PlantSeed:Fire(pos, seedType, tool)
    end)

    if ok then
        PlantStatus:SetText("Status: Planted " .. tostring(seedType))
    else
        PlantStatus:SetText("Status: Fire error")
    end
end

