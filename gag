    end
end

-- =============================================
--  BUY LOGIC (Seed Shop) — skips out-of-stock seeds
-- =============================================
local _seedBuyList  = {}
local _seedBuyIndex = 1

local function tryBuy()
    local selected = Options.ShopSeeds.Value
    if not selected or not next(selected) then
        BuyStatus:SetText("Status: No seeds selected")
        return
    end

    _seedBuyList = {}
    for seed, active in pairs(selected) do
        if active then table.insert(_seedBuyList, seed) end
    end
    if #_seedBuyList == 0 then return end

    local tries = 0
    local seed = nil
    while tries < #_seedBuyList do
        if _seedBuyIndex > #_seedBuyList then _seedBuyIndex = 1 end
        local candidate = _seedBuyList[_seedBuyIndex]
        _seedBuyIndex = _seedBuyIndex + 1
        tries = tries + 1
        if inStock("SeedShop", candidate) then
            seed = candidate
            break
        end
    end

    if not seed then
        BuyStatus:SetText("Status: All out of stock")
        return
    end

    local ok = pcall(function()
        Networking.SeedShop.PurchaseSeed:Fire(seed)
    end)

    if ok then
        BuyStatus:SetText("Status: Bought " .. seed)
    else
        BuyStatus:SetText("Status: Failed / cooldown")
    end
end

