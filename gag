-- =============================================
--  PLOT HELPER
-- =============================================
local function getMyPlot()
    local plotId  = player:GetAttribute("PlotId")
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end

    if plotId then
        local p = gardens:FindFirstChild("Plot" .. tostring(plotId))
        if p then return p end
    end

    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, pf in ipairs(plants:GetChildren()) do
                if pf.Name:sub(1, #uid) == uid then
                    return plot
                end
            end
        end
    end

    return nil
end

-- =============================================
--  SEED TOOL HELPER
-- =============================================
local function getSeedToolMatching(wanted)
    local function scan(container)
        if not container then return nil end
        for _, t in ipairs(container:GetChildren()) do
            if t:IsA("Tool") then
                local seedType = t:GetAttribute("SeedTool")
                if seedType ~= nil then
                    if not wanted or not next(wanted) then
                        return t, seedType
                    end
                    if wanted[tostring(seedType)] then
                        return t, seedType
                    end
                end
            end
        end
        return nil
    end

    local char = player.Character
    local t, seedType = scan(char)
    if t then return t, seedType end

    local bp = player:FindFirstChildOfClass("Backpack")
    return scan(bp)
end

-- =============================================
--  PLANT AREA HELPER
-- =============================================
local function getPlantAreas(plot)
    local areas = {}
    local visual = plot:FindFirstChild("Visual")
    if not visual then return areas end

    for _, child in ipairs(visual:GetChildren()) do
        if child:IsA("BasePart") and child.Name:find("PlantAreaColumn") then
            table.insert(areas, child)
        end
    end
    return areas
end

local function randomPointOnPart(part)
    local size = part.Size
    local offX = (math.random() - 0.5) * size.X
    local offZ = (math.random() - 0.5) * size.Z
    local localPoint = Vector3.new(offX, size.Y / 2, offZ)
    return part.CFrame:PointToWorldSpace(localPoint)
end

-- =============================================
--  STOCK HELPER
--  Reads "xN in Stock" from each item's GUI in the shop frame.
-- =============================================
local PlayerGui = player:WaitForChild("PlayerGui")

local function getStock(shopGuiName, itemName)
    local gui = PlayerGui:FindFirstChild(shopGuiName)
    if not gui then return nil end

    local entry = gui:FindFirstChild(itemName, true)
    if not entry then return nil end

    local stockText = entry:FindFirstChild("Stock_Text", true)
    if stockText and stockText:IsA("TextLabel") then
        local n = tostring(stockText.Text):match("x?(%d+)")
        if n then return tonumber(n) end
    end

    local costText = entry:FindFirstChild("Cost_Text", true)
    if costText and costText:IsA("TextLabel") then
        if tostring(costText.Text):upper():find("NO STOCK") then
            return 0
        end
        return 1
    end

    return nil
end

local function inStock(shopGuiName, itemName)
    local s = getStock(shopGuiName, itemName)
    if s == nil then return true end
    return s > 0
end

-- =============================================
--  HARVEST LOGIC
-- =============================================
local function harvestAll()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then
        HarvestStatus:SetText("Status: No Gardens found")
        return
    end

    local triggered = 0

    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if not plants then continue end

        for _, playerFolder in ipairs(plants:GetChildren()) do
            if playerFolder.Name:sub(1, #uid) ~= uid then continue end

            for _, desc in ipairs(playerFolder:GetDescendants()) do
                if not Alive() or not Toggles.AutoHarvest.Value then return end

                if desc:IsA("ProximityPrompt") then
                    pcall(function() fireproximityprompt(desc) end)
                    triggered = triggered + 1
                    task.wait(Options.HarvestDelay.Value)
                end
            end
        end
    end

    if triggered > 0 then
        HarvestStatus:SetText("Status: Got " .. triggered .. " crops")
    else
        HarvestStatus:SetText("Status: Nothing ready")
    end
end

