local mailUserCache = {}

local function lookupUser(username)
    local key = username:lower()
    if mailUserCache[key] then return mailUserCache[key] end

    local ok, id = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if ok and typeof(id) == "number" and id > 0 then
        mailUserCache[key] = id
        return id
    end
    return nil
end

local function buildMailBatch()
    local items = {}
    if not PlayerStateClient then return items, "No PlayerStateClient" end

    local replica
    pcall(function() replica = PlayerStateClient:GetLocalReplica() end)
    local inv = replica and replica.Data and replica.Data.Inventory
    if typeof(inv) ~= "table" then return items, "No inventory" end

    local sendAll   = Toggles.MailAllCats.Value
    local catFilter = Options.MailCats.Value
    local skipPets  = Toggles.MailSkipPets.Value

    local total = 0

    for _, cat in ipairs(GIFTABLE_CATEGORIES) do
        if total >= 20 then break end
        if cat == "Pets" and skipPets then continue end
        if not sendAll and not (catFilter and catFilter[cat]) then continue end

        local catTable = inv[cat]
        if typeof(catTable) ~= "table" then continue end

        if cat == "Pets" or cat == "HarvestedFruits" then
            for id, entry in pairs(catTable) do
                if total >= 20 then break end
                if typeof(entry) == "table" and entry.Id ~= nil then
                    if not (cat == "Pets" and entry.Equipped == true) then
                        table.insert(items, { Category = cat, ItemKey = id, Count = 1 })
                        total = total + 1
                    end
                end
            end
        else
            for itemKey, count in pairs(catTable) do
                if total >= 20 then break end
                if typeof(count) == "number" and count > 0 then
                    local canAdd = math.min(count, 20 - total)
                    if canAdd > 0 then
                        table.insert(items, { Category = cat, ItemKey = itemKey, Count = canAdd })
                        total = total + canAdd
                    end
                end
            end
        end
    end

    return items
end

local function sendMailOnce()
    local username = (Options.MailTarget.Value or ""):gsub("^%s*@?(.-)%s*$", "%1")
    if username == "" then
        MailStatus:SetText("Status: No recipient")
        return false
    end

    if #username < 3 or #username > 20 or not username:match("^[%w_]+$") then
        MailStatus:SetText("Status: Bad username")
        return false
    end

    MailStatus:SetText("Status: Looking up...")
    local userId = lookupUser(username)
    if not userId then
        MailStatus:SetText("Status: User not found")
        return false
    end

    local items = buildMailBatch()
    if #items == 0 then
        MailStatus:SetText("Status: Nothing to send")
        return false
    end

    local note = Options.MailNote.Value or ""

    local ok, success, msg = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, items, note)
    end)

    if ok and success then
        mailSent = mailSent + 1
        MailCountL:SetText("Sent: " .. mailSent)
        MailStatus:SetText("Status: Sent batch of " .. #items)
        return true
    else
        MailStatus:SetText("Status: " .. (typeof(msg) == "string" and msg ~= "" and msg or "Send failed"))
        return false
    end
end

