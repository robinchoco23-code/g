do
    pcall(function()
        local vu = game:GetService("VirtualUser")
        player.Idled:Connect(function()
            if not Toggles.AntiAfk.Value then return end
            vu:CaptureController()
            vu:ClickButton2(Vector2.new())
        end)
    end)

    task.spawn(function()
        local VIM = game:GetService("VirtualInputManager")
        while Alive() do
            if Toggles.AntiAfk.Value then
                pcall(function()
                    player:SetAttribute("AntiAfkIdleOverride", 1e9)
                end)
                pcall(function()
                    VIM:SendKeyEvent(true,  Enum.KeyCode.Space, false, game)
                    task.wait(0.05)
                    VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
                end)
                AntiAfkStatus:SetText("Status: On (idle blocked)")
            else
                pcall(function()
                    player:SetAttribute("AntiAfkIdleOverride", 0)
                end)
                AntiAfkStatus:SetText("Status: Off")
            end
            task.wait(60)
        end
    end)
end

