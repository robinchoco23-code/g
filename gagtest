-- =============================================
--  PERFORMANCE LOOP
-- =============================================
task.spawn(function()
    local lastRender = nil
    local lastFps    = nil
    while Alive() do
        task.wait(0.5)
        local wantDisable = Toggles.Disable3DRender.Value
        if wantDisable ~= lastRender then
            lastRender = wantDisable
            pcall(function() RunService:Set3dRenderingEnabled(not wantDisable) end)
        end
        local wantFps = Options.FpsCap.Value
        if wantFps ~= lastFps then
            lastFps = wantFps
            pcall(function() setfpscap(wantFps) end)
        end
    end
    pcall(function() RunService:Set3dRenderingEnabled(true) end)
end)

-- =============================================
--  TIMED AUTO HOP
-- =============================================
task.spawn(function()
    while Alive() do
        if Toggles.AutoHop.Value then
            local target  = math.max(1, Options.HopInterval.Value) * 60
            local elapsed = 0
            while Alive() and Toggles.AutoHop.Value and elapsed < target do
                task.wait(1); elapsed = elapsed + 1
            end
            if Alive() and Toggles.AutoHop.Value then
                pcall(function() Networking.AntiAfk.RequestHop:Fire() end); task.wait(5)
            end
        else
            task.wait(1)
        end
    end
end)

