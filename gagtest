-- =============================================
--  STOP FUNCTION
-- =============================================
_G._gag_stop = function()
    _alive = false
    _G._gag_mail_once = false
    _G._gag_webhook_test = false

    -- restore graphics
    pcall(restorePerf)

    -- drop harvest connections
    for _, c in ipairs(harvestConns) do pcall(function() c:Disconnect() end) end
    table.clear(harvestConns)
    table.clear(harvestPrompts)

    pcall(function() player:SetAttribute("AntiAfkIdleOverride", 0) end)
    pcall(function() Library:Unload() end)
end
