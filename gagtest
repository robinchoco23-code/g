-- =============================================
local _collectList = {}

local function collectDrops()
    local container = workspace:FindFirstChild("DroppedItems"); if not container then return end
    local root = getRoot(); if not root then return end
    local returnCF = root.CFrame
    table.clear(_collectList)
    for _, model in ipairs(container:GetChildren()) do
        if model:IsA("Model") then
            local restricted = model:GetAttribute("OwnerRestricted") == true
            local droppedBy  = model:GetAttribute("DroppedBy")
            if not (restricted and droppedBy ~= player.UserId) then
                for _, d in ipairs(model:GetDescendants()) do
                    if d:IsA("ProximityPrompt") then
                        local part = d.Parent
                        if not (part and part:IsA("BasePart")) then part = d:FindFirstAncestorWhichIsA("BasePart") end
                        table.insert(_collectList, { prompt = d, part = part, model = model }); break
                    end
                end
            end
        end
    end
    if #_collectList == 0 then return end
    table.sort(_collectList, function(a, b)
        if not (a.part and b.part) then return false end
        return (a.part.Position - returnCF.Position).Magnitude < (b.part.Position - returnCF.Position).Magnitude
    end)

    local collected = false

    if Toggles.DropsTeleport.Value then
        for _, entry in ipairs(_collectList) do
            if not Alive() or not Toggles.AutoDrops.Value then break end
            local prompt, part, model = entry.prompt, entry.part, entry.model
            if not (prompt and prompt.Parent and model and model.Parent and part and part.Parent) then continue end
            local oldHold = prompt.HoldDuration
            pcall(function() prompt.HoldDuration = 0 end)
            for attempt = 1, 6 do
                if not (prompt.Parent and model.Parent and part.Parent) then break end
                moveTo(CFrame.new(part.Position + Vector3.new(0, 3, 0)))
                task.wait(0.12 + attempt * 0.04)
                if not (prompt.Parent and part.Parent) then break end
                pcall(function() fireproximityprompt(prompt) end)
                task.wait(0.12)
                if not model.Parent then collected = true; break end
            end
            pcall(function() if prompt and prompt.Parent then prompt.HoldDuration = oldHold end end)
            task.wait(Options.DropsDelay.Value)
        end
    else
        for _, entry in ipairs(_collectList) do
            local p = entry.prompt
            if p and p.Parent then entry.oldHold = p.HoldDuration; pcall(function() p.HoldDuration = 0 end) end
        end
        for _ = 1, 3 do
            if not Alive() or not Toggles.AutoDrops.Value then break end
            local anyLeft = false
            for _, entry in ipairs(_collectList) do
                if entry.prompt and entry.prompt.Parent and entry.model and entry.model.Parent then
                    anyLeft = true; pcall(function() fireproximityprompt(entry.prompt) end)
                end
            end
            if not anyLeft then break end
            task.wait(Options.DropsDelay.Value)
        end
        for _, entry in ipairs(_collectList) do
            if entry.prompt and entry.prompt.Parent and entry.oldHold ~= nil then
                pcall(function() entry.prompt.HoldDuration = entry.oldHold end)
            end
        end
        for _, entry in ipairs(_collectList) do
            if not entry.model.Parent then collected = true; break end
        end
    end

    if collected then returnTo(returnCF, Toggles.DropsReturn.Value) end
end

