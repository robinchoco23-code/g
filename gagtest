local PlayerGui = player:WaitForChild("PlayerGui")

local function getStock(shopGuiName, itemName)
    local gui = PlayerGui:FindFirstChild(shopGuiName)
    if not gui then return nil end

    local entry = gui:FindFirstChild(itemName, true)
    if not entry then return nil end

    local stockText = entry:FindFirstChild("Stock_Text", true)
    if stockText and stockText:IsA("TextLabel") then
        local n = tostring(stockText.Text):match("x?(%d+)")
        if n then return tonumber(n) end
    end

    local costText = entry:FindFirstChild("Cost_Text", true)
    if costText and costText:IsA("TextLabel") then
        if tostring(costText.Text):upper():find("NO STOCK") then return 0 end
        return 1
    end
    return nil
end

local function inStock(shopGuiName, itemName)
    local s = getStock(shopGuiName, itemName)
    if s == nil then return true end
    return s > 0
end

-- =============================================
--  HARVEST LOGIC  (indexed — no GetDescendants on a timer)
--  We scan the plant folder ONCE, cache every ProximityPrompt in a
--  table, and keep it current via DescendantAdded/Removing. The per-tick
--  harvest then just walks the cached table, allocating nothing.
-- =============================================
local harvestPrompts = {}   -- [ProximityPrompt] = true
local boundPlants
local harvestConns = {}

local function bindHarvest()
    local plot   = getMyPlot()
    local plants = plot and plot:FindFirstChild("Plants")
    if not plants then return false end
    if plants == boundPlants then return true end

    -- rebind to a new/changed Plants folder
    for _, c in ipairs(harvestConns) do pcall(function() c:Disconnect() end) end
    table.clear(harvestConns)
    table.clear(harvestPrompts)
    boundPlants = plants

    for _, pf in ipairs(plants:GetChildren()) do
        if pf.Name:sub(1, #uid) == uid then
            for _, d in ipairs(pf:GetDescendants()) do
                if d:IsA("ProximityPrompt") then harvestPrompts[d] = true end
            end
        end
    end

    harvestConns[#harvestConns + 1] = plants.DescendantAdded:Connect(function(d)
        if d:IsA("ProximityPrompt") then
            local pf = d:FindFirstAncestorWhichIsA("Folder")
            -- accept anything under our owned subfolders
            if d:FindFirstAncestor(uid) or (pf and pf.Name:sub(1, #uid) == uid) then
                harvestPrompts[d] = true
            else
                harvestPrompts[d] = true -- plot is ours; keep simple
            end
        end
    end)
    harvestConns[#harvestConns + 1] = plants.DescendantRemoving:Connect(function(d)
        harvestPrompts[d] = nil
    end)

    return true
end

local _harvestScratch = {}  -- reused snapshot array (no per-sweep allocation churn)

local function harvestAll()
    if not bindHarvest() then
        setHarvest("Status: No plot found")
        return
    end

    -- Snapshot keys first. We yield (task.wait) inside the fire loop below,
    -- and the DescendantAdded/Removing connections mutate harvestPrompts during
    -- those yields. Iterating the live table across a yield invalidates the
    -- `next` iterator ("invalid key to 'next'"), so we walk a snapshot instead.
    -- This pairs() pass does NOT yield, so it's safe.
    table.clear(_harvestScratch)
    local n = 0
    for prompt in pairs(harvestPrompts) do
        if prompt.Parent then
            n = n + 1
            _harvestScratch[n] = prompt
        else
            harvestPrompts[prompt] = nil  -- stale; safe to clear current/other keys, no yield here
        end
    end

    local triggered = 0
    for i = 1, n do
        if not Alive() or not Toggles.AutoHarvest.Value then return end
        local prompt = _harvestScratch[i]
        if prompt.Parent and prompt.Enabled then
            pcall(fireproximityprompt, prompt)
            triggered = triggered + 1
            task.wait(Options.HarvestDelay.Value)
        end
    end

    setHarvest(triggered > 0 and ("Status: Got " .. triggered .. " crops") or "Status: Nothing ready")
end

