-- =============================================
do
    -- handle the "Reset Hunt Flag" button as soon as it's pressed
    task.spawn(function()
        while Alive() do
            if _G._gag_hunt_reset then
                _G._gag_hunt_reset = false
                fileDel(HUNT_DONE_FILE)
                setHunt("Status: Flag cleared")
            end
            task.wait(0.4)
        end
    end)

    task.spawn(function()
        while Alive() do
            if not Toggles.PetHunt.Value then
                setHunt("Status: Idle")
                task.wait(1)
                continue
            end

            -- Stop if we already bought on a previous (pre-hop) session.
            if not Toggles.HuntKeepGoing.Value and fileGet(HUNT_DONE_FILE) then
                setHunt("Status: Done (target bought). Reset to hunt again.")
                task.wait(2)
                continue
            end

            local targets = Options.HuntPets.Value
            if not targets or not next(targets) then
                setHunt("Status: No target selected")
                task.wait(1)
                continue
            end

            -- wait for the character + for wild pets to populate this server
            local waited = 0
            while Alive() and not getRoot() and waited < 15 do task.wait(0.5); waited = waited + 0.5 end

            setHunt("Status: Letting server load...")
            task.wait(math.max(1, Options.HuntLoadWait.Value))
            if not Toggles.PetHunt.Value then continue end

            -- a few scan passes in case pets stream in a little late
            local entry
            for _ = 1, 4 do
                if not Toggles.PetHunt.Value then break end
                entry = select(1, scanForTargetPet())
                if entry then break end
                setHunt("Status: Scanning...")
                task.wait(1)
            end

            if entry then
                local root = getRoot()
                local returnCF = root and root.CFrame
                setHunt("Status: Found " .. (entry.ptype or "pet") .. " — buying")

                local bought = false
                pcall(function() bought = buyOnePet(entry) end)

                -- confirm: target prompt should be gone after a successful buy
                task.wait(0.5)
                local stillThere = select(1, scanForTargetPet())
                if bought and not (stillThere and stillThere.ptype == entry.ptype) then
                    setHunt("Status: Bought " .. (entry.ptype or "pet") .. "!")
                    if returnCF then returnTo(returnCF, true) end

                    if not Toggles.HuntKeepGoing.Value then
                        fileSet(HUNT_DONE_FILE, "1")
                        Toggles.PetHunt:SetValue(false)   -- stop hunting this session
                        setHunt("Status: Done (target bought)")
                    else
                        -- keep going: hop for the next one
                        task.wait(1)
                        setHunt("Status: Hopping for more...")
                        pcall(function() Networking.AntiAfk.RequestHop:Fire() end)
                        task.wait(8)
                    end
                else
                    setHunt("Status: Buy failed — hopping")
                    if returnCF then returnTo(returnCF, true) end
                    pcall(function() Networking.AntiAfk.RequestHop:Fire() end)
                    task.wait(8)
                end
            else
                setHunt("Status: Not here — hopping")
                pcall(function() Networking.AntiAfk.RequestHop:Fire() end)
                task.wait(8)  -- teleport usually fires within this window
            end
        end
    end)
end

-- =============================================
--  AUTO SKIP LOADING SCREEN  ("click to skip")
--  Event-driven: catches the prompt on first exec and after each hop,
--  without polling the GUI tree. Also does one initial sweep in case the
--  screen is already present when the script runs.
-- =============================================
do
    local SKIP_PATTERNS = { "click to skip", "tap to skip", "skip" }
    local lastSkip = 0

    local function looksLikeSkip(obj)
        if not (obj:IsA("TextLabel") or obj:IsA("TextButton")) then return false end
        local t = tostring(obj.Text):lower()
        if t == "" then return false end
        for _, pat in ipairs(SKIP_PATTERNS) do
            if t:find(pat, 1, true) then return true end
        end
        return false
    end

    local function fireSkip(obj)
        if not Toggles.SkipLoading.Value then return end
        if tick() - lastSkip < 1 then return end  -- debounce
        lastSkip = tick()

        local done = false

        -- 1) If the executor can fire signals, hit the button's click events directly.
        if typeof(firesignal) == "function" then
            for _, sigName in ipairs({ "MouseButton1Click", "Activated", "MouseButton1Down", "MouseButton1Up" }) do
                pcall(function()
                    local sig = obj[sigName]
                    if sig then firesignal(sig); done = true end
                end)
            end
        end

        -- 2) Fallback / catch-all: simulate a real click at the element's center.
        --    Many "click to skip" overlays accept a click anywhere, so this also
        --    covers labels that aren't buttons.
        pcall(function()
            local VIM = game:GetService("VirtualInputManager")
            local pos = obj.AbsolutePosition + obj.AbsoluteSize / 2
            VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, true,  game, 0)
            task.wait(0.05)
            VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 0)
            done = true
        end)

        setLoad(done and "Status: Skipped loading screen" or "Status: Found skip, click failed")
    end

    local function sweep()
        if not Toggles.SkipLoading.Value then return end
        for _, obj in ipairs(PlayerGui:GetDescendants()) do
            if looksLikeSkip(obj) and obj.Visible ~= false then
                fireSkip(obj)
                return
            end
        end
    end

    -- Watch for the prompt appearing (text is often set just after the
    -- instance is parented, so defer a beat before checking).
    PlayerGui.DescendantAdded:Connect(function(d)
        if not Toggles.SkipLoading.Value then return end
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            task.defer(function()
                task.wait(0.1)
                if d.Parent and looksLikeSkip(d) and d.Visible ~= false then
                    fireSkip(d)
                end
            end)
        end
    end)

    -- Initial bounded sweep for the first few seconds after exec.
    task.spawn(function()
        local t0 = tick()
        while Alive() and tick() - t0 < 20 do
            if Toggles.SkipLoading.Value then sweep() end
            task.wait(0.5)
        end
        if Toggles.SkipLoading.Value then setLoad("Status: Watching") end
    end)
end

