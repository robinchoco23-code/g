--  MAILBOX SEND LOGIC
-- =============================================
local mailUserCache = {}

local function lookupUser(username)
    local key = username:lower()
    if mailUserCache[key] then return mailUserCache[key] end
    local ok, id = pcall(function() return Networking.Mailbox.LookupPlayer:Fire(username) end)
    if ok and typeof(id) == "number" and id > 0 then mailUserCache[key] = id; return id end
    return nil
end

local function validUsername(username)
    return username ~= "" and #username >= 3 and #username <= 20 and username:match("^[%w_]+$") ~= nil
end

local _mailItems = {}

local function buildMailBatch(maxItems)
    maxItems = maxItems or 20; if maxItems > 20 then maxItems = 20 end
    table.clear(_mailItems)
    local selectedCats = Options.MailCategories.Value
    if not selectedCats or not next(selectedCats) then return _mailItems, 0 end
    if not PlayerStateClient then return _mailItems, 0 end
    local replica; pcall(function() replica = PlayerStateClient:GetLocalReplica() end)
    local inv = replica and replica.Data and replica.Data.Inventory
    if typeof(inv) ~= "table" then return _mailItems, 0 end
    local total = 0
    for _, cat in ipairs(GIFTABLE_CATEGORIES) do
        if total >= maxItems then break end
        if not selectedCats[cat] then continue end
        local catTable = inv[cat]; if typeof(catTable) ~= "table" then continue end
        if cat == "Pets" or cat == "HarvestedFruits" then
            for id, entry in pairs(catTable) do
                if total >= maxItems then break end
                if typeof(entry) == "table" and entry.Id ~= nil then
                    if not (cat == "Pets" and isPetEquipped(id, entry)) then
                        table.insert(_mailItems, { Category = cat, ItemKey = id, Count = 1 }); total = total + 1
                    end
                end
            end
        else
            for itemKey, count in pairs(catTable) do
                if total >= maxItems then break end
                if typeof(count) == "number" and count > 0 then
                    local canAdd = math.min(count, maxItems - total)
                    if canAdd > 0 then
                        table.insert(_mailItems, { Category = cat, ItemKey = itemKey, Count = canAdd })
                        total = total + canAdd
                    end
                end
            end
        end
    end
    return _mailItems, total
end

local function sendMailOnce()
    local username = (Options.MailTarget.Value or ""):gsub("^%s*@?(.-)%s*$", "%1")
    if not validUsername(username) then return false end
    if username:lower() == player.Name:lower() then return false end
    local items = buildMailBatch(20); if #items == 0 then return false end
    local userId = lookupUser(username); if not userId then return false end
    local note = Options.MailNote.Value or ""
    local ok, success = pcall(function() return Networking.Mailbox.SendBatch:Fire(userId, items, note) end)
    return ok and success == true
end

-- =============================================
--  CUSTOM ITEM MAIL
--  Searches actual inventory — partial name ok
-- =============================================
local function sendCustomMailOnce()
    local username = (Options.CustomMailTarget.Value or ""):gsub("^%s*@?(.-)%s*$", "%1")
    if not validUsername(username) then print("[Mail] custom: bad/missing recipient username"); return false end
    if username:lower() == player.Name:lower() then print("[Mail] custom: can't mail yourself"); return false end

    local rawInput = (Options.CustomMailItemKey.Value or ""):gsub("^%s*(.-)%s*$", "%1")
    if rawInput == "" then print("[Mail] custom: no item name entered"); return false end
    local searchKey = rawInput:lower()

    if not PlayerStateClient then print("[Mail] custom: PlayerStateClient not available"); return false end
    local replica; pcall(function() replica = PlayerStateClient:GetLocalReplica() end)
    local inv = replica and replica.Data and replica.Data.Inventory
    if typeof(inv) ~= "table" then print("[Mail] custom: inventory not available"); return false end

    local foundCategory, foundKey, foundCount, isInstanced = nil, nil, 0, false

    for _, cat in ipairs(GIFTABLE_CATEGORIES) do
        local catTable = inv[cat]
        if typeof(catTable) ~= "table" then continue end
        for itemKey, val in pairs(catTable) do
            local keyLower    = tostring(itemKey):lower()
            local displayName = ""
            if typeof(val) == "table" then
                displayName = tostring(val.Name or val.SeedType or val.Type or ""):lower()
            end
            if keyLower:find(searchKey, 1, true) or displayName:find(searchKey, 1, true) then
                foundCategory = cat; foundKey = itemKey
                if typeof(val) == "number" then foundCount = val; isInstanced = false
                else foundCount = 1; isInstanced = true end
                break
            end
        end
        if foundCategory then break end
    end

    if not foundCategory then
        print("[Mail] custom: '" .. rawInput .. "' not found in your inventory")
        print("[Mail] Tip: partial names work — try 'carr' for Carrot, 'drag' for Dragon Fruit")
        return false
    end

    local wantAmount = tonumber(Options.CustomMailAmount.Value) or 1
    if wantAmount < 1 then wantAmount = 1 end
    local sendCount = isInstanced and 1 or math.min(wantAmount, foundCount)

    local userId = lookupUser(username)
    if not userId then print("[Mail] custom: recipient user not found"); return false end

    local items = { { Category = foundCategory, ItemKey = foundKey, Count = sendCount } }
    local note  = Options.CustomMailNote.Value or ""
    local ok, success = pcall(function() return Networking.Mailbox.SendBatch:Fire(userId, items, note) end)

    if ok and success then
        print(string.format("[Mail] sent %dx '%s' (%s) to %s", sendCount, foundKey, foundCategory, username))
        return true
    end
    print("[Mail] custom: send failed"); return false
end

