        pcall(function() if isfile(name) then delfile(name) end end)
    end
end

-- Returns the nearest matching target pet entry in this server, or nil.
local function scanForTargetPet()
    local targets = Options.HuntPets.Value
    if not targets or not next(targets) then return nil, "No target selected" end

    local map = workspace:FindFirstChild("Map")
    local spawns = map and map:FindFirstChild("WildPetSpawns")
    if not spawns then return nil, "No WildPetSpawns" end

    local root = getRoot()
    local origin = root and root.Position or Vector3.zero

    local best, bestDist
    for _, prompt in ipairs(spawns:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and prompt.Enabled then
            local action = (prompt.ActionText or ""):lower()
            if action == "" or action:find("buy") then
                local owner = prompt:FindFirstAncestorWhichIsA("Model")
                local part = owner and (owner.PrimaryPart
                    or owner:FindFirstChild("HumanoidRootPart")
                    or owner:FindFirstChildWhichIsA("BasePart"))
                if part then
                    local pType = petTypeFromName(owner.Name)
                    if pType and targets[pType] then
                        local d = (part.Position - origin).Magnitude
                        if not bestDist or d < bestDist then
                            best, bestDist = { prompt = prompt, part = part, ptype = pType }, d
                        end
                    end
                end
            end
        end
    end
    return best
end

-- =============================================
--  AUTO DROPS LOGIC  (closures hoisted)
-- =============================================
local function scanContainerPrompts(container, out)
    if not container then return end
    for _, desc in ipairs(container:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local part = desc.Parent
            if not (part and part:IsA("BasePart")) then
                part = desc:FindFirstAncestorWhichIsA("BasePart")
            end
            if part then table.insert(out, { prompt = desc, part = part }) end
        end
    end
end

local function guaranteedFire(prompt)
    if not prompt or not prompt.Parent then return false end
    local oldHold = 0
    pcall(function() oldHold = prompt.HoldDuration; prompt.HoldDuration = 0 end)

    local fired = false
    for _ = 1, 3 do
        if not prompt.Parent then break end
        local ok = pcall(function() fireproximityprompt(prompt) end)
        if ok then fired = true break end
        task.wait(0.05)
    end

    pcall(function()
        if prompt and prompt.Parent then prompt.HoldDuration = oldHold end
    end)
    return fired
end

local _dropPrompts = {}

local function collectDrops()
    local root = getRoot()
    if not root then setDrops("Status: No character") return end

    local returnCF = root.CFrame

    table.clear(_dropPrompts)
    pcall(function()
        scanContainerPrompts(workspace:FindFirstChild("DroppedItems"), _dropPrompts)
        local map = workspace:FindFirstChild("Map")
        if map then
            scanContainerPrompts(map:FindFirstChild("SeedPackSpawnClient"), _dropPrompts)
            scanContainerPrompts(map:FindFirstChild("SeedPackSpawnServerLocations"), _dropPrompts)
        end
    end)

    if #_dropPrompts == 0 then
        setDrops("Status: Nothing to collect")
        returnTo(returnCF, Toggles.DropsReturn.Value)
        return
    end

    table.sort(_dropPrompts, function(a, b)
        return (a.part.Position - returnCF.Position).Magnitude
             < (b.part.Position - returnCF.Position).Magnitude
    end)

    local collected = 0
    for _, entry in ipairs(_dropPrompts) do
        if not Alive() or not Toggles.AutoDrops.Value then break end

        local prompt, part = entry.prompt, entry.part
        if prompt and prompt.Parent and part and part.Parent then
            local r = getRoot()
            if not r then break end

            r.CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0))
            task.wait(0.15)

            if guaranteedFire(prompt) then
                collected = collected + 1
                setDrops("Status: Collecting... (" .. collected .. ")")
            end
            task.wait(Options.DropsDelay.Value)
        end
    end

    setDrops(collected > 0 and ("Status: Got " .. collected .. " drop(s)") or "Status: Nothing collected")
    returnTo(returnCF, Toggles.DropsReturn.Value)
end

-- =============================================
--  PERFORMANCE / POTATO MODE
-- =============================================
local EFFECT_CLASSES = {
    ParticleEmitter = true, Trail = true, Beam = true,
    Fire = true, Smoke = true, Sparkles = true,
}

-- saved originals so we can restore on unload / toggle-off
local _perfSaved = {
    quality   = nil,
    shadows   = nil,
    fogEnd    = nil,
    fogStart  = nil,
    terrainDecoration = nil,
    waterWaveSize = nil,
    waterReflectance = nil,
}
local _perfApplied = false
local _perfConn = nil

local function saveOriginals()
    if _perfSaved.quality ~= nil then return end
    pcall(function() _perfSaved.quality  = settings().Rendering.QualityLevel end)
    _perfSaved.shadows  = Lighting.GlobalShadows
    _perfSaved.fogEnd   = Lighting.FogEnd
    _perfSaved.fogStart = Lighting.FogStart
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        _perfSaved.terrainDecoration = terrain.Decoration
        _perfSaved.waterWaveSize     = terrain.WaterWaveSize
        _perfSaved.waterReflectance  = terrain.WaterReflectance
    end
end

local function setEffectsEnabled(enabled)
    -- one-time sweep; not on a timer
    pcall(function()
        for _, d in ipairs(workspace:GetDescendants()) do
            if EFFECT_CLASSES[d.ClassName] then
                d.Enabled = enabled
            end
        end
    end)
end

local function applyPotato()
    saveOriginals()

    if Toggles.LowQuality.Value then
        pcall(function()
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        end)
    end

    if Toggles.NoShadows.Value then
        pcall(function() Lighting.GlobalShadows = false end)
    end

    -- view distance via fog
    local vd = Options.ViewDistance.Value
    pcall(function()
        Lighting.FogStart = math.max(0, vd - 50)
        Lighting.FogEnd   = vd
    end)

    if Toggles.NoTerrainDecor.Value then
        local terrain = workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            pcall(function()
                terrain.Decoration      = false
                terrain.WaterWaveSize   = 0
                terrain.WaterReflectance = 0
            end)
        end
    end

    if Toggles.KillEffects.Value then
        setEffectsEnabled(false)
        -- keep new effects suppressed while potato mode is on
        if not _perfConn then
            _perfConn = workspace.DescendantAdded:Connect(function(d)
                if Toggles.PotatoMode.Value and Toggles.KillEffects.Value
                   and EFFECT_CLASSES[d.ClassName] then
                    pcall(function() d.Enabled = false end)
                end
            end)
        end
    end

    _perfApplied = true
    setPerf("Status: On (" .. math.floor(vd) .. " studs)")
end

local function restorePerf()
    if not _perfApplied then setPerf("Status: Off") return end

    if _perfConn then pcall(function() _perfConn:Disconnect() end) _perfConn = nil end

    pcall(function()
        if _perfSaved.quality ~= nil then
            settings().Rendering.QualityLevel = _perfSaved.quality
        end
    end)
    if _perfSaved.shadows  ~= nil then pcall(function() Lighting.GlobalShadows = _perfSaved.shadows end) end
    if _perfSaved.fogEnd   ~= nil then pcall(function() Lighting.FogEnd   = _perfSaved.fogEnd   end) end
    if _perfSaved.fogStart ~= nil then pcall(function() Lighting.FogStart = _perfSaved.fogStart end) end

    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        if _perfSaved.terrainDecoration ~= nil then pcall(function() terrain.Decoration      = _perfSaved.terrainDecoration end) end
        if _perfSaved.waterWaveSize     ~= nil then pcall(function() terrain.WaterWaveSize    = _perfSaved.waterWaveSize     end) end
        if _perfSaved.waterReflectance  ~= nil then pcall(function() terrain.WaterReflectance = _perfSaved.waterReflectance  end) end
    end

    setEffectsEnabled(true)

    _perfApplied = false
    setPerf("Status: Off")
end

-- React to the view-distance slider live while potato mode is on
Options.ViewDistance:OnChanged(function()
    if Toggles.PotatoMode.Value and _perfApplied then
        local vd = Options.ViewDistance.Value
        pcall(function()
            Lighting.FogStart = math.max(0, vd - 50)
            Lighting.FogEnd   = vd
        end)
        setPerf("Status: On (" .. math.floor(vd) .. " studs)")
    end
end)

-- Re-apply if any of the fine toggles change while master is on
local function reapplyIfOn()
    if Toggles.PotatoMode.Value then
        restorePerf()
        applyPotato()
    end
end
Toggles.KillEffects:OnChanged(reapplyIfOn)
Toggles.NoShadows:OnChanged(reapplyIfOn)
Toggles.LowQuality:OnChanged(reapplyIfOn)
Toggles.NoTerrainDecor:OnChanged(reapplyIfOn)

Toggles.PotatoMode:OnChanged(function()
    if Toggles.PotatoMode.Value then applyPotato() else restorePerf() end
end)

