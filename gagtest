--  PLOT HELPER
-- =============================================
local function getMyPlot()
    local plotId  = player:GetAttribute("PlotId")
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end

    if plotId then
        local p = gardens:FindFirstChild("Plot" .. tostring(plotId))
        if p then return p end
    end

    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, pf in ipairs(plants:GetChildren()) do
                if pf.Name:sub(1, #uid) == uid then return plot end
            end
        end
    end
    return nil
end

-- =============================================
--  SEED TOOL HELPER
-- =============================================
local function getSeedToolMatching(wanted)
    local function scan(container)
        if not container then return nil end
        for _, t in ipairs(container:GetChildren()) do
            if t:IsA("Tool") then
                local seedType = t:GetAttribute("SeedTool")
                if seedType ~= nil then
                    if not wanted or not next(wanted) then return t, seedType end
                    if wanted[tostring(seedType)] then return t, seedType end
                end
            end
        end
        return nil
    end

    local char = player.Character
    local t, seedType = scan(char)
    if t then return t, seedType end
    return scan(player:FindFirstChildOfClass("Backpack"))
end

-- =============================================
--  PLANT AREA HELPER
-- =============================================
local function getPlantAreas(plot)
    local areas = {}
    local visual = plot:FindFirstChild("Visual")
    if not visual then return areas end
    for _, child in ipairs(visual:GetChildren()) do
        if child:IsA("BasePart") and child.Name:find("PlantAreaColumn") then
            table.insert(areas, child)
        end
    end
    return areas
end

local function randomPointOnPart(part)
    local size = part.Size
    local offX = (math.random() - 0.5) * size.X
    local offZ = (math.random() - 0.5) * size.Z
    return part.CFrame:PointToWorldSpace(Vector3.new(offX, size.Y / 2, offZ))
end

-- True if world XZ (x,z) sits inside this part's footprint (handles rotation).
local function xzInsidePart(part, x, z)
    local rel = part.CFrame:PointToObjectSpace(Vector3.new(x, part.Position.Y, z))
    return math.abs(rel.X) <= part.Size.X / 2
       and math.abs(rel.Z) <= part.Size.Z / 2
end

-- Pick a point in a ring around the player (minDist..radius) that still lands
-- on a valid plant area, so seeds plant near you but never directly on you.
local function pointNearPlayer(areas, radius)
    local root = getRoot()
    if not root then return nil end

    local origin  = root.Position
    local minDist = 5                      -- never plant on top of the player
    if radius <= minDist then radius = minDist + 1 end

    for _ = 1, 24 do
        local ang  = math.random() * 2 * math.pi
        local dist = minDist + math.random() * (radius - minDist)
        local x = origin.X + math.cos(ang) * dist
        local z = origin.Z + math.sin(ang) * dist
        for _, area in ipairs(areas) do
            if xzInsidePart(area, x, z) then
                local topY = area.Position.Y + area.Size.Y / 2
                return Vector3.new(x, topY, z)
            end
        end
    end
    return nil  -- no valid spot found in range
end

