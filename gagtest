-- =============================================
--  STATUS LABEL HELPER (dedups SetText so idle loops
--  don't poke the UI / allocate strings every tick)
-- =============================================
local function statusSetter(label)
    local last
    return function(txt)
        if txt ~= last then
            last = txt
            label:SetText(txt)
        end
    end
end

