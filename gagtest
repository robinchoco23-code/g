-- =============================================
--  MAILBOX SEND LOGIC
-- =============================================
local mailUserCache = {}

local function lookupUser(username)
    local key = username:lower()
    if mailUserCache[key] then return mailUserCache[key] end

    local ok, id = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if ok and typeof(id) == "number" and id > 0 then
        mailUserCache[key] = id
        return id
    end
    return nil
end

local _mailItems = {}

local function buildMailBatch(maxItems)
    maxItems = maxItems or 20
    if maxItems > 20 then maxItems = 20 end

    table.clear(_mailItems)
    if not PlayerStateClient then return _mailItems, 0, "No PlayerStateClient" end

    local replica
    pcall(function() replica = PlayerStateClient:GetLocalReplica() end)
    local inv = replica and replica.Data and replica.Data.Inventory
    if typeof(inv) ~= "table" then return _mailItems, 0, "No inventory" end

    local sendAll   = Toggles.MailAllCats.Value
    local catFilter = Options.MailCats.Value
    local skipPets  = Toggles.MailSkipPets.Value

    local total = 0
    for _, cat in ipairs(GIFTABLE_CATEGORIES) do
        if total >= maxItems then break end
        if not (cat == "Pets" and skipPets) then
            if sendAll or (catFilter and catFilter[cat]) then
                local catTable = inv[cat]
                if typeof(catTable) == "table" then
                    if cat == "Pets" or cat == "HarvestedFruits" then
                        for id, entry in pairs(catTable) do
                            if total >= maxItems then break end
                            if typeof(entry) == "table" and entry.Id ~= nil then
                                if not (cat == "Pets" and entry.Equipped == true) then
                                    table.insert(_mailItems, { Category = cat, ItemKey = id, Count = 1 })
                                    total = total + 1
                                end
                            end
                        end
                    else
                        for itemKey, count in pairs(catTable) do
                            if total >= maxItems then break end
                            if typeof(count) == "number" and count > 0 then
                                local canAdd = math.min(count, maxItems - total)
                                if canAdd > 0 then
                                    table.insert(_mailItems, { Category = cat, ItemKey = itemKey, Count = canAdd })
                                    total = total + canAdd
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    return _mailItems, total
end

local function summariseBatch(items, total, username)
    local byCat, order = {}, {}
    for _, it in ipairs(items) do
        if not byCat[it.Category] then table.insert(order, it.Category) end
        byCat[it.Category] = (byCat[it.Category] or 0) + it.Count
    end

    local lines = {}
    for _, cat in ipairs(order) do
        table.insert(lines, "• " .. cat .. ": " .. byCat[cat])
    end

    return string.format("📬 **Mailed %d item(s)** to `%s`\n%s",
        total, username, table.concat(lines, "\n"))
end

local function sendMailOnce()
    local username = (Options.MailTarget.Value or ""):gsub("^%s*@?(.-)%s*$", "%1")
    if username == "" then setMail("Status: No recipient") return false end

    if #username < 3 or #username > 20 or not username:match("^[%w_]+$") then
        setMail("Status: Bad username") return false
    end

    local batchSize = math.floor(Options.MailBatchSize.Value)
    local items, total = buildMailBatch(batchSize)

    if #items == 0 then setMail("Status: Nothing to send") return false end

    if Toggles.MailWaitFull.Value and total < batchSize then
        setMail(string.format("Status: Waiting (%d/%d)", total, batchSize))
        return false
    end

    setMail("Status: Looking up...")
    local userId = lookupUser(username)
    if not userId then setMail("Status: User not found") return false end

    local note = Options.MailNote.Value or ""

    local ok, success, msg = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, items, note)
    end)

    if ok and success then
        setMail("Status: Sent batch of " .. total)
        if Toggles.WebhookEnabled.Value then
            sendWebhook(summariseBatch(items, total, username))
        end
        return true
    else
        setMail("Status: " .. (typeof(msg) == "string" and msg ~= "" and msg or "Send failed"))
        return false
    end
end

