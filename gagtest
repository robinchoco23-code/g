local function getRequestFn()
    return (syn and syn.request)
        or (http and http.request)
        or http_request or request
        or (fluxus and fluxus.request)
        or nil
end

local function sendWebhook(content)
    local url = Options.WebhookUrl.Value
    if not url or url == "" then return false end
    local req = getRequestFn()
    if not req then return false end
    local ok = pcall(function()
        req({
            Url = url, Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ content = content }),
        })
    end)
    return ok
end

-- =============================================
--  MAILBOX SEND LOGIC
-- =============================================
local mailUserCache = {}

local function lookupUser(username)
    local key = username:lower()
    if mailUserCache[key] then return mailUserCache[key] end
    local ok, id = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(username)
    end)
    if ok and typeof(id) == "number" and id > 0 then
        mailUserCache[key] = id
        return id
    end
    return nil
end

local _mailItems = {}

-- =============================================
--  INVENTORY SCANNER
--  Reads the local replica, builds a display string per unique item
--  (e.g. "Deer [200x]", "Carrot [150x]"), and populates the picker
--  dropdown. _invMap maps display string → how to build a mail entry.
-- =============================================
local _invMap = {}  -- display → { cat, key, count, instanced, keys? }

-- Stackable categories: inv[cat][itemKey] = count (number)
local STACKABLE_CATS = {
    "Seeds", "Sprinklers", "WateringCans", "Mushrooms", "Gnomes",
    "Raccoons", "Crates", "SeedPacks", "Trowels", "Props", "EmptyPots",
}
-- Per-instance categories: inv[cat][instanceId] = { Id = typeId, ... }
local INSTANCED_CATS = { "Pets", "HarvestedFruits" }

local function refreshInventory()
    table.clear(_invMap)

    if not PlayerStateClient then
        setMailScan("Error: No PlayerStateClient")
        return
    end

    local replica
    pcall(function() replica = PlayerStateClient:GetLocalReplica() end)
    local inv = replica and replica.Data and replica.Data.Inventory
    if typeof(inv) ~= "table" then
        setMailScan("Error: No inventory data")
        return
    end

    local skipPets = Toggles.MailSkipPets.Value

    -- Stackable items
    for _, cat in ipairs(STACKABLE_CATS) do
        local catTable = inv[cat]
        if typeof(catTable) == "table" then
            for itemKey, count in pairs(catTable) do
                if typeof(count) == "number" and count > 0 then
                    local display = itemKey .. " [" .. count .. "x]"
                    _invMap[display] = {
                        cat      = cat,
                        key      = itemKey,
                        count    = count,
                        instanced = false,
                    }
                end
            end
        end
    end

    -- Per-instance items: group by type Id so "Deer [200x]" shows total
    for _, cat in ipairs(INSTANCED_CATS) do
        if cat == "Pets" and skipPets then continue end

        local catTable = inv[cat]
        if typeof(catTable) == "table" then
            local grouped = {}   -- typeId → { instanceKeys }
            for instanceKey, entry in pairs(catTable) do
                if typeof(entry) == "table" and entry.Id ~= nil then
                    local typeId = tostring(entry.Id)
                    if not grouped[typeId] then grouped[typeId] = {} end
                    -- skip equipped pets
                    if not (cat == "Pets" and entry.Equipped == true) then
                        table.insert(grouped[typeId], instanceKey)
                    end
                end
            end
            for typeId, keys in pairs(grouped) do
                if #keys > 0 then
                    local suffix = cat == "Pets" and " (Pet)" or " (Fruit)"
                    local display = typeId .. " [" .. #keys .. "x]" .. suffix
                    _invMap[display] = {
                        cat       = cat,
                        keys      = keys,
                        count     = #keys,
                        instanced = true,
                    }
                end
            end
        end
    end

    -- Build a sorted list and push it to the dropdown
    local values = {}
    local total  = 0
    for display in pairs(_invMap) do
        table.insert(values, display)
        total = total + 1
    end
    table.sort(values)

    if total == 0 then
        setMailScan("Inventory appears empty")
        return
    end

    -- Update the dropdown values & clear current selection
    pcall(function()
        Options.MailItems:SetValues(values)
        Options.MailItems:SetValue({})
    end)

    setMailScan("Found " .. total .. " item type(s) — pick below")
end

-- =============================================
--  BUILD MAIL BATCH from selected inventory items
-- =============================================
local function buildMailBatch(maxItems)
    maxItems = maxItems or 20
    if maxItems > 20 then maxItems = 20 end

    table.clear(_mailItems)

    local total    = 0
    local skipPets = Toggles.MailSkipPets.Value

    if Toggles.MailSendAll.Value then
        -- ── Send All mode: scan inventory directly, no picker needed ──
        if not PlayerStateClient then return _mailItems, 0 end

        local replica
        pcall(function() replica = PlayerStateClient:GetLocalReplica() end)
        local inv = replica and replica.Data and replica.Data.Inventory
        if typeof(inv) ~= "table" then return _mailItems, 0 end

        for _, cat in ipairs(GIFTABLE_CATEGORIES) do
            if total >= maxItems then break end
            if cat == "Pets" and skipPets then continue end

            local catTable = inv[cat]
            if typeof(catTable) ~= "table" then continue end

            if cat == "Pets" or cat == "HarvestedFruits" then
                for id, entry in pairs(catTable) do
                    if total >= maxItems then break end
                    if typeof(entry) == "table" and entry.Id ~= nil then
                        if not (cat == "Pets" and entry.Equipped == true) then
                            table.insert(_mailItems, { Category = cat, ItemKey = id, Count = 1 })
                            total = total + 1
                        end
                    end
                end
            else
                for itemKey, count in pairs(catTable) do
                    if total >= maxItems then break end
                    if typeof(count) == "number" and count > 0 then
                        local canAdd = math.min(count, maxItems - total)
                        if canAdd > 0 then
                            table.insert(_mailItems, { Category = cat, ItemKey = itemKey, Count = canAdd })
                            total = total + canAdd
                        end
                    end
                end
            end
        end
    else
        -- ── Picker mode: use whatever the user selected in the dropdown ──
        local selected = Options.MailItems.Value
        if not selected or not next(selected) then
            return _mailItems, 0
        end

        for display, active in pairs(selected) do
            if not active or total >= maxItems then continue end
            local info = _invMap[display]
            if not info then continue end

            if info.instanced then
                for _, instanceKey in ipairs(info.keys) do
                    if total >= maxItems then break end
                    table.insert(_mailItems, { Category = info.cat, ItemKey = instanceKey, Count = 1 })
                    total = total + 1
                end
            else
                local canAdd = math.min(info.count, maxItems - total)
                if canAdd > 0 then
                    table.insert(_mailItems, { Category = info.cat, ItemKey = info.key, Count = canAdd })
                    total = total + canAdd
                end
            end
        end
    end

    return _mailItems, total
end

local function summariseBatch(items, total, username)
    local byCat, order = {}, {}
    for _, it in ipairs(items) do
        if not byCat[it.Category] then table.insert(order, it.Category) end
        byCat[it.Category] = (byCat[it.Category] or 0) + it.Count
    end
    local lines = {}
    for _, cat in ipairs(order) do
        table.insert(lines, "• " .. cat .. ": " .. byCat[cat])
    end
    return string.format("📬 **Mailed %d item(s)** to `%s`\n%s",
        total, username, table.concat(lines, "\n"))
end

local function sendMailOnce()
    local username = (Options.MailTarget.Value or ""):gsub("^%s*@?(.-)%s*$", "%1")
    if username == "" then setMail("Status: No recipient") return false end
    if #username < 3 or #username > 20 or not username:match("^[%w_]+$") then
        setMail("Status: Bad username") return false
    end

    -- Block self-sends
    if username:lower() == player.Name:lower() then
        setMail("Status: Can't mail yourself")
        return false
    end

    -- Refresh inventory for picker mode so counts stay current.
    -- Send All mode reads the replica directly inside buildMailBatch, no pre-scan needed.
    if not Toggles.MailSendAll.Value then
        refreshInventory()
    end

    local batchSize = math.floor(Options.MailBatchSize.Value)
    local items, total = buildMailBatch(batchSize)
    if #items == 0 then setMail("Status: Nothing to send") return false end

    if Toggles.MailWaitFull.Value and total < batchSize then
        setMail(string.format("Status: Waiting (%d/%d)", total, batchSize))
        return false
    end

    setMail("Status: Looking up...")
    local userId = lookupUser(username)
    if not userId then setMail("Status: User not found") return false end

    local note = Options.MailNote.Value or ""
    local ok, success, msg = pcall(function()
        return Networking.Mailbox.SendBatch:Fire(userId, items, note)
    end)

    if ok and success then
        setMail("Status: Sent batch of " .. total)
        if Toggles.WebhookEnabled.Value then
            sendWebhook(summariseBatch(items, total, username))
        end
        return true
    else
        setMail("Status: " .. (typeof(msg) == "string" and msg ~= "" and msg or "Send failed"))
        return false
    end
end

-- =============================================
--  ACCEPT MAIL LOGIC
--  Tries ClaimAll first (one fire, most efficient). If that remote
--  doesn't exist or returns nothing, falls back to fetching the mailbox
--  list and claiming each entry individually.
-- =============================================
local function tryAcceptMail()
    -- Fire OpenInbox first to tell the server to load the inbox.
    -- The first call initialises it; we wait a beat then call again to read it.
    pcall(function() Networking.Mailbox.OpenInbox:Fire() end)
    task.wait(0.5)

    local inbox = nil
    pcall(function() inbox = Networking.Mailbox.OpenInbox:Fire() end)
    if not inbox then
        pcall(function() inbox = Networking.Mailbox.List:Fire() end)
    end

    if typeof(inbox) ~= "table" or not next(inbox) then
        setAccept("Status: Inbox empty")
        return
    end

    local claimed = 0
    for entryKey in pairs(inbox) do
        local ok = pcall(function()
            Networking.Mailbox.Claim:Fire(entryKey)
        end)
        if ok then
            claimed = claimed + 1
            task.wait(0.15)
        end
    end

    setAccept(claimed > 0 and ("Status: Claimed " .. claimed .. " mail(s)") or "Status: Nothing claimed")
end

