--  SELL LOGIC
-- =============================================
local function trySell()
    local preview = nil
    pcall(function() preview = Networking.NPCS.PreviewSellAll:Fire() end)
    if not preview then setSell("Status: Preview failed") return end

    local fruitCount = preview.FruitCount or 0
    if fruitCount == 0 then setSell("Status: Nothing to sell") return end

    local result = nil
    pcall(function() result = Networking.NPCS.SellAll:Fire() end)

    if result and result.Success then
