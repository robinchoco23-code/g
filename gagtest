local function petMatches(petName, petSize, isRainbow)
    if Toggles.BuyAllPets.Value then return true end
    if not petName then return false end
    local wanted = Options.PetTypes.Value
    local isWantedType = (wanted and wanted[petName] == true) or false
    local isWantedSize = false
    if Toggles.MatchBig.Value     and petSize == "Big"  then isWantedSize = true end
    if Toggles.MatchHuge.Value    and petSize == "Huge" then isWantedSize = true end
    if Toggles.MatchRainbow.Value and isRainbow         then isWantedSize = true end
    if Toggles.FilterByType.Value then return isWantedType and isWantedSize end
    return isWantedType or isWantedSize
end

local function findBuyPrompt(model)
    local part = model.PrimaryPart or model:FindFirstChild("RootPart") or model:FindFirstChildWhichIsA("BasePart")
    if not part then return nil, nil end
    return part:FindFirstChild("BuyPrompt") or part:FindFirstChildOfClass("ProximityPrompt"), part
end

local function collectPetPrompts()
    local ok, list = pcall(function()
        local map = workspace:FindFirstChild("Map")
        local spawns = map and map:FindFirstChild("WildPetSpawns")
        if not spawns then return nil end
        local out = {}
        for _, model in ipairs(spawns:GetChildren()) do
            if model:IsA("Model") then
                local prompt, part = findBuyPrompt(model)
                if prompt and prompt.Enabled and part then
                    local petName   = model:GetAttribute("PetName")
                    local petSize   = model:GetAttribute("PetSize")
                    local isRainbow = model:HasTag("PetRainbow") or model:GetAttribute("PetType") == "Rainbow"
                    if petMatches(petName, petSize, isRainbow) then
                        table.insert(out, { prompt = prompt, part = part, ptype = petName })
                    end
                end
            end
        end
        return out
    end)
    if not ok then return nil end
    return list
end

local function findRefPart(model, petName)
    local map = workspace:FindFirstChild("Map")
    local refFolder = map and map:FindFirstChild("WildPetRef")
    if not refFolder then return nil end
    local prefix  = "WildPet_" .. tostring(petName) .. "_"
    local refName = model.Name
    if refName:sub(1, #prefix) == prefix then refName = refName:sub(#prefix + 1) end
    return refFolder:FindFirstChild(refName)
end

local function buyOnePet(entry)
    local prompt, part = entry.prompt, entry.part
    if not prompt or not prompt.Parent or not part or not part.Parent then return false end
    local model   = part:FindFirstAncestorOfClass("Model")
    local refPart = model and findRefPart(model, entry.ptype)
    local oldHold = prompt.HoldDuration
    pcall(function() prompt.HoldDuration = 0 end)
    local fired = false
    for attempt = 1, 8 do
        if not prompt.Parent or not part.Parent then break end
        moveTo(part.CFrame + Vector3.new(0, 3, 0))
        task.wait(0.15 + (attempt * 0.05))
        if not prompt.Parent then break end
        local promptOk = pcall(function() fireproximityprompt(prompt) end)
        local directOk = false
        if refPart then directOk = pcall(function() Networking.Pets.WildPetTame:Fire(refPart) end) end
        if promptOk or directOk then
            fired = true; task.wait(0.1)
            if not prompt.Parent or not part.Parent then break end
        end
    end
    pcall(function() if prompt and prompt.Parent then prompt.HoldDuration = oldHold end end)
    return fired
end

