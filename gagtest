--  PLOT HELPER
-- =============================================
local function getMyPlot()
    local plotId  = player:GetAttribute("PlotId")
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end

    if plotId then
        local p = gardens:FindFirstChild("Plot" .. tostring(plotId))
        if p then return p end
    end

    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, pf in ipairs(plants:GetChildren()) do
                if pf.Name:sub(1, #uid) == uid then return plot end
            end
        end
    end
    return nil
end

-- =============================================
--  SEED TOOL HELPER
-- =============================================
local function getSeedToolMatching(wanted)
    local function scan(container)
        if not container then return nil end
        for _, t in ipairs(container:GetChildren()) do
            if t:IsA("Tool") then
                local seedType = t:GetAttribute("SeedTool")
                if seedType ~= nil then
                    if not wanted or not next(wanted) then return t, seedType end
                    if wanted[tostring(seedType)] then return t, seedType end
                end
            end
        end
        return nil
    end

    local char = player.Character
    local t, seedType = scan(char)
    if t then return t, seedType end
    return scan(player:FindFirstChildOfClass("Backpack"))
end

-- =============================================
--  SHARED CHARACTER HELPER
-- =============================================
local function getRoot()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- =============================================
--  PLANT AREA HELPER
-- =============================================
local function getPlantAreas(plot)
    local areas = {}
    local visual = plot:FindFirstChild("Visual")
    if not visual then return areas end
    for _, child in ipairs(visual:GetChildren()) do
        if child:IsA("BasePart") and child.Name:find("PlantAreaColumn") then
            table.insert(areas, child)
        end
    end
    return areas
end

local function randomPointOnPart(part)
    local size = part.Size
    local offX = (math.random() - 0.5) * size.X
    local offZ = (math.random() - 0.5) * size.Z
    return part.CFrame:PointToWorldSpace(Vector3.new(offX, size.Y / 2, offZ))
end

-- Pick a point near the player: choose a spot in the ring (minDist..radius)
-- around you *first*, then keep it only if it lands on a valid plant area.
-- Sampling in the ring directly (polar) means even a tiny radius works — every
-- candidate is already in range, so we only reject points that are off a bed.
-- Returns nil if nothing in range is on a bed (e.g. you're standing off-plot).
local function pointNearPlayer(areas, radius)
    local root = getRoot()
    if not root then return nil end

    local origin  = root.Position
    local minDist = 3                       -- close, but never on top of you
    if radius <= minDist then radius = minDist + 0.5 end

    for _ = 1, 60 do
        local ang  = math.random() * 2 * math.pi
        local dist = minDist + math.random() * (radius - minDist)
        local wx = origin.X + math.cos(ang) * dist
        local wz = origin.Z + math.sin(ang) * dist

        for _, area in ipairs(areas) do
            -- footprint test in the part's own space (handles rotated plots)
            local rel = area.CFrame:PointToObjectSpace(Vector3.new(wx, area.Position.Y, wz))
            if math.abs(rel.X) <= area.Size.X / 2 and math.abs(rel.Z) <= area.Size.Z / 2 then
                -- return the surface point directly above that footprint spot
                return area.CFrame:PointToWorldSpace(Vector3.new(rel.X, area.Size.Y / 2, rel.Z))
            end
        end
    end
    return nil
end

-- =============================================
--  STOCK HELPER
-- =============================================
local PlayerGui = player:WaitForChild("PlayerGui")

local function getStock(shopGuiName, itemName)
    local gui = PlayerGui:FindFirstChild(shopGuiName)
    if not gui then return nil end

    local entry = gui:FindFirstChild(itemName, true)
    if not entry then return nil end

    local stockText = entry:FindFirstChild("Stock_Text", true)
    if stockText and stockText:IsA("TextLabel") then
        local n = tostring(stockText.Text):match("x?(%d+)")
        if n then return tonumber(n) end
    end

    local costText = entry:FindFirstChild("Cost_Text", true)
    if costText and costText:IsA("TextLabel") then
        if tostring(costText.Text):upper():find("NO STOCK") then return 0 end
        return 1
    end
    return nil
end

local function inStock(shopGuiName, itemName)
    local s = getStock(shopGuiName, itemName)
    if s == nil then return true end
    return s > 0
end

-- =============================================
--  HARVEST LOGIC
--  Scans live each sweep into a reused scratch array.
--  Fast (sees ready crops immediately) and crash-safe
--  (fire loop walks the array, not the live world).
-- =============================================
local _harvestScratch = {}

local function harvestAll()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then
        setHarvest("Status: No Gardens found")
        return
    end

    table.clear(_harvestScratch)
    local n = 0
    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, pf in ipairs(plants:GetChildren()) do
                if pf.Name:sub(1, #uid) == uid then
                    for _, d in ipairs(pf:GetDescendants()) do
                        if d:IsA("ProximityPrompt") and d.Enabled then
                            n = n + 1
                            _harvestScratch[n] = d
                        end
                    end
                end
            end
        end
    end

    local triggered = 0
    for i = 1, n do
        if not Alive() or not Toggles.AutoHarvest.Value then return end
        local prompt = _harvestScratch[i]
        if prompt.Parent and prompt.Enabled then
            pcall(fireproximityprompt, prompt)
            triggered = triggered + 1
            task.wait(Options.HarvestDelay.Value)
        end
    end

    setHarvest(triggered > 0 and ("Status: Got " .. triggered .. " crops") or "Status: Nothing ready")
end

-- =============================================
--  SELL LOGIC
-- =============================================
local function trySell()
    local preview = nil
    pcall(function() preview = Networking.NPCS.PreviewSellAll:Fire() end)
    if not preview then setSell("Status: Preview failed") return end

    local fruitCount = preview.FruitCount or 0
    if fruitCount == 0 then setSell("Status: Nothing to sell") return end

    local result = nil
    pcall(function() result = Networking.NPCS.SellAll:Fire() end)

    if result and result.Success then
        setSell(string.format("Status: Sold %d items", result.SoldCount or fruitCount))
    else
        setSell("Status: Failed / cooldown")
    end
end

-- =============================================
--  BUY LOGIC (Seed Shop)
-- =============================================
local _seedBuyList  = {}
local _seedBuyIndex = 1

local function tryBuy()
    local selected = Options.ShopSeeds.Value
    if not selected or not next(selected) then setBuy("Status: No seeds selected") return end

    table.clear(_seedBuyList)
    for seed, active in pairs(selected) do
        if active then table.insert(_seedBuyList, seed) end
    end
    if #_seedBuyList == 0 then return end

    local tries, seed = 0, nil
    while tries < #_seedBuyList do
        if _seedBuyIndex > #_seedBuyList then _seedBuyIndex = 1 end
        local candidate = _seedBuyList[_seedBuyIndex]
        _seedBuyIndex = _seedBuyIndex + 1
        tries = tries + 1
