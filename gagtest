local TOOL_ATTR_MAP = {
    SeedTool = "Seeds", HarvestedFruit = "HarvestedFruits",
    Sprinkler = "Sprinklers", WateringCan = "WateringCans",
    Mushroom = "Mushrooms", Gnome = "Gnomes", Raccoon = "Raccoons",
    Crate = "Crates", SeedPack = "SeedPacks", Trowel = "Trowels", EmptyPot = "EmptyPots",
}

local function getToolDropInfo(tool)
    if tool:GetAttribute("HarvestedFruit") == true then
        local id = tool:GetAttribute("Id"); if id then return "HarvestedFruits", id end
    end
    local petId = tool:GetAttribute("PetId")
    if type(petId) == "string" and petId ~= "" then return "Pets", petId end
    for attr in pairs(tool:GetAttributes()) do
        local cat = TOOL_ATTR_MAP[attr]
        if cat then local val = tool:GetAttribute(attr); if val then return cat, val end end
    end
    return nil, nil
end

local function dropOneItem()
    local selected = Options.DropCategories.Value
    if not selected or not next(selected) then return end
    local char = player.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local backpack = player:FindFirstChildOfClass("Backpack")
    if not (char and humanoid and backpack) then return end
    local function categoryWanted(cat)
        if cat == "Pets" and Toggles.DropSkipPets.Value then return false end
        return selected[cat] == true
    end
    local equipped = char:FindFirstChildOfClass("Tool")
    if equipped then
        local cat, id = getToolDropInfo(equipped)
        if cat and categoryWanted(cat) then
            pcall(function() Networking.DroppedItem.RequestDrop:Fire(cat, id) end); return
        end
    end
    for _, tool in ipairs(backpack:GetChildren()) do
        if not Alive() or not Toggles.AutoDropItems.Value then return end
        if tool:IsA("Tool") then
            local cat, id = getToolDropInfo(tool)
            if cat and categoryWanted(cat) then
                humanoid:EquipTool(tool); task.wait(0.1)
                local stillCat, stillId = getToolDropInfo(tool)
                if stillCat and tool.Parent == char then
                    pcall(function() Networking.DroppedItem.RequestDrop:Fire(stillCat, stillId) end); return
                end
            end
        end
    end
end

